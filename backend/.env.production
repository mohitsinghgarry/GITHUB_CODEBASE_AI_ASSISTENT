# Production Environment Configuration
# IMPORTANT: Update all sensitive values before deploying

# Application
APP_NAME=GitHub Codebase RAG Assistant
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["https://your-domain.com"]

# Database
DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/github_rag_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis-host:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://redis-host:6379/1
CELERY_RESULT_BACKEND=redis://redis-host:6379/2

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama:7b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNK_SIZE=1024

# Search
DEFAULT_TOP_K=10
MAX_TOP_K=100
HYBRID_SEARCH_ALPHA=0.5

# RAG
MAX_CONTEXT_TOKENS=4096
MAX_RESPONSE_TOKENS=2048
RAG_TEMPERATURE=0.7

# Session
SESSION_TTL_HOURS=24
CACHE_TTL_HOURS=1

# Storage
REPO_STORAGE_PATH=/data/repositories
FAISS_INDEX_PATH=/data/indices

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Security
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
