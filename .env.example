# Docker Compose Environment Variables
# Copy this file to .env and customize for your environment

# ============================================================================
# Security
# ============================================================================
# IMPORTANT: Change this to a secure random string (min 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-min-32-chars-required-use-openssl-rand

# Grafana admin password
GRAFANA_PASSWORD=admin

# ============================================================================
# Service Ports (Optional - defaults are set in docker-compose.yml)
# ============================================================================
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# OLLAMA_PORT=11434
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001

# ============================================================================
# Database Configuration (Optional)
# ============================================================================
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=github_rag

# ============================================================================
# Ollama Configuration (Optional)
# ============================================================================
# OLLAMA_MODEL=codellama:7b
# Alternative models:
# - deepseek-coder:6.7b
# - llama2:13b
# - mistral:7b

# ============================================================================
# Resource Limits (Optional)
# ============================================================================
# BACKEND_MEMORY_LIMIT=2G
# CELERY_MEMORY_LIMIT=2G
# OLLAMA_MEMORY_LIMIT=4G

# ============================================================================
# Development Settings
# ============================================================================
# Set to 'true' to enable development mode
# DEV_MODE=false
